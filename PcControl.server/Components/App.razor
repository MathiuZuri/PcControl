<script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>

<script>
        window.generarQr = (elementoId, texto) => {
            document.getElementById(elementoId).innerHTML = ""; // Limpiar anterior
            new QRCode(document.getElementById(elementoId), {
                text: texto,
                width: 200,
                height: 200
            });
        }
</script>

