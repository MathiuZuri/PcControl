@using PcControl.Shared.Models
@using PcControl.Server.Services
@inject ComputadoraService ComputerService

<div class="col-md-3 col-sm-6 mb-4">
    <div class="card h-100 shadow-sm @ObtenerClaseBorde() @(!Pc.EstaOnline ? "opacity-75" : "")">
        
        <div class="card-header d-flex justify-content-between align-items-center @ObtenerClaseFondo()">
            <h5 class="m-0 text-white text-truncate" title="@Pc.Nombre">
                @Pc.Nombre 
                @if (!string.IsNullOrEmpty(Pc.NotaAdmin))
                {
                    <i class="bi bi-sticky-fill text-warning ms-2" title="@Pc.NotaAdmin"></i>
                }
            </h5>
            
            @if (Pc.EstaOnline)
            {
                <span class="badge bg-light text-dark">@Pc.Estado</span>
            }
            else
            {
                <span class="badge bg-dark text-white border border-secondary">OFFLINE</span>
            }
        </div>

        <div class="card-body text-center d-flex flex-column justify-content-center">
            
            @if (!Pc.EstaOnline)
            {
                <h1 class="display-4 text-secondary mb-0"><i class="bi bi-power"></i></h1>
    
                @if(Pc.Estado == "Ocupada")
                {
                    @if(IsPaused)
                    {
                        <p class="text-warning text-dark fw-bold mb-1">¡Tiempo Pausado!</p>
                    }
                    else
                    {
                        <p class="text-danger fw-bold mb-1">¡Sesión Interrumpida!</p>
                    }
                        
                    <h3 class="text-primary fw-bold my-2">@Pc.TotalGeneral.ToString("C")</h3>
                    <small class="text-muted d-block mb-3">Equipo desconectado.</small>

                    <div class="btn-group w-100 mt-auto">
                        <button class="btn btn-secondary" @onclick="AlquilarClick" title="Opciones">
                            <i class="bi bi-gear-fill"></i>
                        </button>
                            
                        @* Botón de Pausa actualizado con IsPaused *@
                        <button class="btn @(IsPaused ? "btn-info text-white" : "btn-outline-info")" 
                                @onclick="() => ComputerService.AlternarPausaAsync(Pc.Id, !IsPaused)" 
                                title="Pausar tiempo en el servidor">
                            <i class="bi @(IsPaused ? "bi-play-fill" : "bi-pause-fill")"></i>
                        </button>

                        <button class="btn btn-danger" @onclick="CobrarClick">
                            Cobrar
                        </button>
                    </div>
                }
                else
                {
                    <p class="text-muted">Sin conexión / Apagada</p>
                    <button class="btn btn-secondary w-100 mt-auto" @onclick="AlquilarClick">
                        <i class="bi bi-power"></i> Opciones / Encender
                    </button>
                }
            }
            
            else if (Pc.Estado == "Disponible")
            {
                <h1 class="display-4 text-success"><i class="bi bi-pc-display"></i></h1>
                <p class="text-muted">Libre para usar</p>
                <button class="btn btn-outline-success w-100 mt-auto" @onclick="AlquilarClick">
                    <i class="bi bi-play-fill"></i> Iniciar
                </button>
            }
            
            else
            {
                <h1 class="display-4 text-danger mb-0"><i class="bi bi-person-workspace"></i></h1>
                <h3 class="text-primary fw-bold my-2">@Pc.TotalGeneral.ToString("C")</h3>
                
                <div class="small text-muted mb-2">
                    <div>Inicio: @Pc.HoraInicio?.ToString("hh:mm tt")</div>
                    @if (Pc.ImporteExtra > 0)
                    {
                        <div class="text-danger fw-bold">(+ @Pc.ImporteExtra.ToString("C") Extras)</div>
                    }
                </div>

                @if (Pc.TiempoLimiteMinutos > 0)
                {
                    <div class="mb-3">
                        @if (Pc.InicioPausa != null)
                        {
                            <span class="badge bg-warning text-dark fs-6 animate-pulse">
                                <i class="bi bi-pause-fill"></i> TIEMPO PAUSADO
                            </span>
                        }
                        else
                        {
                            <span class="badge @(Pc.MinutosRestantes < 5 ? "bg-danger" : "bg-warning text-dark") fs-6">
                                <i class="bi bi-hourglass-split"></i> Restan: @Pc.MinutosRestantes min
                            </span>
                        }
                    </div>
                }

                <div class="btn-group w-100 mt-auto">
                    <button class="btn btn-warning" @onclick="AlquilarClick">
                        <i class="bi bi-gear-fill"></i>
                    </button>
                    <button class="btn btn-danger" @onclick="CobrarClick">
                        Cobrar
                    </button>
                    <button type="button" class="btn btn-outline-primary" @onclick="() => OnMensaje.InvokeAsync(Pc)">
                        <i class="bi bi-chat-text-fill"></i>
                    </button>
                </div>
            }
        </div>
    </div>
</div>

@code {
    [Parameter] public Computadora Pc { get; set; } = new();
    [Parameter] public EventCallback<Computadora> OnAlquilar { get; set; } 
    [Parameter] public EventCallback<Computadora> OnCobrar { get; set; }
    [Parameter] public EventCallback<Computadora> OnMensaje { get; set; }

    // --- LA SOLUCIÓN MAGICA ---
    // Verifica si está pausada por el cliente (memoria) o por el administrador (Base de datos)
    private bool IsPaused => Pc.EstaPausada || Pc.InicioPausa != null;

    private async Task AlquilarClick() => await OnAlquilar.InvokeAsync(Pc);
    private async Task CobrarClick() => await OnCobrar.InvokeAsync(Pc);

    private string ObtenerClaseBorde()
    {
        if (IsPaused) return "border-warning"; 
        if (!Pc.EstaOnline) return "border-secondary";
        return Pc.Estado == "Disponible" ? "border-success" : "border-danger";
    }

    private string ObtenerClaseFondo()
    {
        if (IsPaused) return "bg-warning text-dark"; 
        if (!Pc.EstaOnline) return "bg-secondary";
        return Pc.Estado == "Disponible" ? "bg-success" : "bg-danger";
    }
}