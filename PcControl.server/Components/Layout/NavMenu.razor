@using PcControl.Server.Services
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavManager

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">CiberControl Pro</a>
        <button title="Menú" class="navbar-toggler" @onclick="ToggleNavMenu">
            <span class="navbar-toggler-icon"></span>
        </button>
    </div>
</div>

<div class="@NavMenuCssClass nav-scrollable" @onclick="ToggleNavMenu">
    <nav class="flex-column">
        
        <AuthorizeView Roles="Admin, Empleado">
            <Authorized>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                        <i class="bi bi-house-door-fill"></i> Inicio
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="historial">
                        <i class="bi bi-clock-history"></i> Caja Diario
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="productos">
                        <i class="bi bi-shop"></i> Tienda
                    </NavLink>
                </div>
            </Authorized>
        </AuthorizeView>
        
        <AuthorizeView Roles="Admin">
            <Authorized>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="admin-pcs">
                        <i class="bi bi-display"></i> Equipos
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="reportes">
                        <i class="bi bi-graph-up-arrow"></i> Finanzas
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="estadisticas">
                        <i class="bi bi-pie-chart-fill"></i> Estadísticas
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="ajustes">
                        <i class="bi bi-gear-fill"></i> Ajustes
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="configuracionTarifa">
                        <i class="bi bi-cash-coin"></i> Tarifas
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="personalizacion">
                        <span class="bi-image" aria-hidden="true"></span> Personalizar
                    </NavLink>
                </div>
            </Authorized>
        </AuthorizeView>

        <div class="nav-item px-3 mt-4">
            <button class="nav-link btn btn-link text-danger w-100 text-start" @onclick="CerrarSesion">
                <i class="bi bi-box-arrow-left"></i> Salir
            </button>
        </div>
    </nav>
</div>

@code {
    private bool collapseNavMenu = true;

    // Esta propiedad cambia la clase CSS dinámicamente
    private string? NavMenuCssClass => collapseNavMenu ? "collapse" : null;

    private void ToggleNavMenu()
    {
        collapseNavMenu = !collapseNavMenu;
    }

    private void CerrarSesion()
    {
        if (AuthStateProvider is CustomAuthStateProvider auth)
        {
            auth.Logout();
            NavManager.NavigateTo("/login", true);
        }
    }
}