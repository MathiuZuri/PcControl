@using System.Net
@using System.Net.Sockets
@inject IJSRuntime Js

<button class="btn d-inline-flex align-items-center gap-2 fw-bold" 
        @onclick="AbrirModal" 
        title="Conectar Celular"
        style="white-space: nowrap; background-color: #00D1FF; color: #151520; border-radius: 8px;">
    
    <i class="bi bi-qr-code-scan"></i>
    <span class="d-none d-sm-inline">App Móvil</span>
</button>

@if (mostrarModal)
{
    <div class="modal-backdrop-custom" 
         style="z-index: 9999; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(5,5,8,0.85); backdrop-filter: blur(5px); display: flex; align-items: center; justify-content: center;">
        
        <div class="modal-content-custom text-center p-4 shadow-lg position-relative" 
             style="max-width: 380px; width: 90%; background-color: #1A1A24; border: 1px solid #00D1FF; border-radius: 16px;">
            
            <button class="btn btn-sm position-absolute top-0 end-0 m-3 text-secondary hover-danger border-0" @onclick="() => mostrarModal = false">
                <i class="bi bi-x-lg fs-5"></i>
            </button>

            <h4 class="fw-bold mb-1" style="color: #00D1FF;"><i class="bi bi-phone-vibrate"></i> Control Móvil</h4>
            <p class="text-muted small mb-4">Escanea el código para administrar el local</p>

            <div class="d-flex justify-content-center mb-4">
                <div id="qrcode" class="p-3 bg-white rounded-3 shadow" style="border: 3px solid #333344;"></div>
            </div>

            <div class="p-2 mb-3 rounded-3" style="background-color: #0F0F15; border: 1px dashed #444;">
                <small class="fw-bold text-info" style="letter-spacing: 1px;">@urlConexion</small>
            </div>
            
            <div class="d-flex align-items-center justify-content-center text-warning opacity-75 mt-2">
                <i class="bi bi-wifi me-2"></i>
                <small class="fst-italic" style="font-size: 0.8rem;">El celular debe estar en la red Wifi local</small>
            </div>
        </div>
    </div>
}

<style>
    .hover-danger:hover { color: #ff4444 !important; }
</style>

@code {
    private bool mostrarModal = false;
    private string urlConexion = "Cargando...";

    private async Task AbrirModal()
    {
        mostrarModal = true;
        
        string ip = await ObtenerIpLocal();
        urlConexion = $"http://{ip}:5249";

        await Task.Delay(100); 
        await Js.InvokeVoidAsync("generarQr", "qrcode", urlConexion);
    }

    private async Task<string> ObtenerIpLocal()
    {
        try
        {
            var hostName = Dns.GetHostName();
            var ips = await Dns.GetHostAddressesAsync(hostName);
            var ipLan = ips.FirstOrDefault(i => 
                i.AddressFamily == AddressFamily.InterNetwork && 
                !IPAddress.IsLoopback(i) && 
                i.ToString().StartsWith("192.168.") && 
                !i.ToString().EndsWith(".1"));
            return ipLan?.ToString() ?? "127.0.0.1";
        }
        catch { return "127.0.0.1"; }
    }
}