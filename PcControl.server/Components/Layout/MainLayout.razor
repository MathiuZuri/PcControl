@inherits LayoutComponentBase
@using PcControl.Server.Services
@using PcControl.server.Components.Layout
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavManager
@inject UiRefreshService RefreshService

<div class="page bg-dark-theme">
    <div class="sidebar shadow-lg">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4 auth d-flex justify-content-between align-items-center shadow-sm" style="background-color: #1A1A24; border-bottom: 1px solid #2A2A35;">
            
            <span class="fw-bold fs-5 d-none d-sm-block" style="color: #00D1FF; letter-spacing: 1px;">
                <i class="bi bi-shield-shaded me-2"></i>AEGIS CIBER
            </span>
            
            <div class="d-flex align-items-center gap-2">
                
                <button class="btn btn-outline-info d-flex align-items-center gap-2 border-0 fw-bold hover-glow" 
                        @onclick="RefrescarDatosActuales" 
                        title="Recargar datos sin salir">
                    <i class="bi bi-arrow-clockwise fs-5"></i>
                    <span class="d-none d-md-inline">Recargar</span>
                </button>

                <div class="vr mx-2" style="background-color: #444; opacity: 1;"></div>

                <MobileConnect />
                
                <div class="vr mx-2" style="background-color: #444; opacity: 1;"></div> 

                <button class="btn btn-outline-danger d-flex align-items-center gap-2 border-0 fw-bold" @onclick="CerrarSesion" title="Cerrar Sesión">
                    <i class="bi bi-power fs-5"></i> 
                    <span class="d-none d-md-inline">Salir</span>
                </button>
            </div>
        </div>

        <article class="content px-4 py-4" style="background-color: #737375; min-height: calc(100vh - 3.5rem);">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" class="bg-danger text-white shadow-lg rounded-3 p-3 text-center" data-nosnippet>
    <i class="bi bi-exclamation-triangle-fill me-2"></i> Ha ocurrido un error en el sistema.
    <a href="." class="reload text-white fw-bold ms-3 border-bottom">Recargar Panel</a>
    <span class="dismiss cursor-pointer ms-3">🗙</span>
</div>

<style>
    .bg-dark-theme { background-color: #0F0F15; }
    .hover-glow:hover { color: #fff !important; text-shadow: 0 0 8px #00D1FF; background: transparent; }
</style>

@code {
    private async Task RefrescarDatosActuales()
    {
        await RefreshService.TriggerRefreshAsync();
    }

    private async Task CerrarSesion()
    {
        if (AuthStateProvider is CustomAuthStateProvider auth)
        {
            await auth.Logout();
            NavManager.NavigateTo("/login", true); 
        }
    }
}