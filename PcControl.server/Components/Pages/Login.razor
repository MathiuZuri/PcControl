@page "/login"
@using PcControl.Server.Data
@using PcControl.Server.Services
@using Microsoft.EntityFrameworkCore
@using PcControl.server.Components.Layout
@using System.Security.Claims

@layout EmptyLayout
@rendermode InteractiveServer

@inject NavigationManager Navigation
@inject AppDbContext DbContext
@inject AuthenticationStateProvider AuthStateProvider

<style>
    /* Estilos para que el input no se ponga blanco feo al hacerle clic */
    .cyber-input:focus {
        background-color: transparent !important;
        color: white !important;
        box-shadow: 0 0 10px rgba(0, 209, 255, 0.3) !important;
        border-color: #00D1FF !important;
    }
    .cyber-input::placeholder {
        color: #495057 !important;
    }
</style>

@if (estaVerificandoSesion)
{
    /* ESTADO 1: PANTALLA DE CARGA (Diseño oscuro) */
    <div class="d-flex flex-column justify-content-center align-items-center vh-100" style="background: radial-gradient(circle at center, #151520 0%, #050508 100%);">
        <div class="spinner-border text-info" role="status" style="width: 4rem; height: 4rem; border-width: 0.3rem;"></div>
        <h4 class="mt-4 text-info" style="letter-spacing: 2px;">Iniciando Sistemas...</h4>
    </div>
}
else
{
    /* ESTADO 2: EL FORMULARIO PREMIUM */
    <div class="d-flex justify-content-center align-items-center vh-100" style="background: radial-gradient(circle at center, #1A1A24 0%, #09090D 100%);">
        
        <div class="card shadow-lg p-5 border-0" style="width: 420px; background-color: #111118; border-radius: 15px; box-shadow: 0 15px 35px rgba(0,0,0,0.5), 0 0 20px rgba(0, 209, 255, 0.1) !important;">
            
            <div class="text-center mb-4">
                <h1 class="display-4 mb-2" style="color: #00D1FF;"><i class="bi bi-shield-lock-fill"></i></h1>
                <h3 class="fw-bold text-white mb-0" style="letter-spacing: 1px;">AegisCiber Admin</h3>
                <p class="text-secondary small mt-1">Acceso seguro al panel principal</p>
            </div>
            
            @if (!string.IsNullOrEmpty(mensajeError))
            {
                <div class="alert alert-danger text-center border-0 fw-bold" style="background-color: #440000; color: #ff6666;">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i> @mensajeError
                </div>
            }

            <form @onsubmit="IniciarSesion" method="post">
                <AntiforgeryToken />
                
                <div class="mb-4">
                    <label class="form-label text-info small fw-bold" style="letter-spacing: 1px;">USUARIO</label>
                    <div class="input-group">
                        <span class="input-group-text bg-transparent border-info text-info"><i class="bi bi-person-fill"></i></span>
                        <input @bind="username" class="form-control cyber-input bg-transparent text-white border-info" placeholder="admin" autocomplete="username" />
                    </div>
                </div>
                
                <div class="mb-5">
                    <label class="form-label text-info small fw-bold" style="letter-spacing: 1px;">CONTRASEÑA</label>
                    <div class="input-group">
                        <span class="input-group-text bg-transparent border-info text-info"><i class="bi bi-key-fill"></i></span>
                        
                        <input @bind="password" type="@(mostrarContrasena ? "text" : "password")" class="form-control cyber-input bg-transparent text-white border-info" placeholder="••••••" autocomplete="current-password" />
                        
                        <button type="button" class="btn btn-outline-info" @onclick="AlternarContrasena" tabindex="-1" title="Mostrar/Ocultar">
                            <i class="bi @(mostrarContrasena ? "bi-eye-slash-fill" : "bi-eye-fill")"></i>
                        </button>
                    </div>
                </div>
                
                <button type="submit" class="btn w-100 fw-bold fs-5 py-2" style="background-color: #00D1FF; color: #111118; border-radius: 8px;">
                    @if (cargando)
                    {
                        <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                        <span>Verificando...</span>
                    }
                    else
                    {
                        <i class="bi bi-box-arrow-in-right me-2"></i>
                        <span>INGRESAR</span>
                    }
                </button>
            </form>
        </div>
    </div>
}

@code {
    private string username = "";
    private string password = "";
    private string mensajeError = "";
    private bool cargando = false;
    
    private bool estaVerificandoSesion = true;
    
    // NUEVA VARIABLE VISUAL: Controla el ojito de la contraseña
    private bool mostrarContrasena = false;

    // NUEVO MÉTODO VISUAL: Cambia el estado del ojito
    private void AlternarContrasena()
    {
        mostrarContrasena = !mostrarContrasena;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            int intentos = 0;
            while (intentos < 5) 
            {
                var authState = await AuthStateProvider.GetAuthenticationStateAsync();
                
                if (authState.User.Identity != null && authState.User.Identity.IsAuthenticated)
                {
                    Navigation.NavigateTo("/"); 
                    return;
                }
                
                await Task.Delay(200);
                intentos++;
            }

            estaVerificandoSesion = false;
            StateHasChanged();
        }
    }

    private async Task IniciarSesion()
    {
        cargando = true;
        mensajeError = "";
        
        try
        {
            string userLimpio = username.Trim();
            string passLimpio = password.Trim();

            var usuarioEncontrado = await DbContext.Usuarios
                .AsNoTracking()
                .FirstOrDefaultAsync(u => u.Username == userLimpio && u.PasswordHash == passLimpio);

            if (usuarioEncontrado != null)
            {
                if (!usuarioEncontrado.Activo)
                {
                    mensajeError = "Usuario inactivo.";
                    cargando = false;
                    return;
                }

                if (AuthStateProvider is CustomAuthStateProvider auth)
                {
                    await auth.Login(usuarioEncontrado);
                    Navigation.NavigateTo("/", forceLoad: true);
                }
            }
            else
            {
                mensajeError = "Credenciales incorrectas.";
            }
        }
        catch (Exception ex)
        {
            mensajeError = "Error: " + ex.Message;
        }
        finally
        {
            cargando = false;
        }
    }
}