@page "/historial"
@using PcControl.Shared.Models
@using PcControl.Server.Services
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@inject HistorialService HistorialService
@inject UiRefreshService RefreshService
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Admin, Empleado")]
@implements IAsyncDisposable

<PageTitle>Historial - Caja Diaria</PageTitle>

<div class="container-fluid mt-3 container-md"> 
    
    <div class="d-flex flex-wrap justify-content-between align-items-center mb-3 gap-2">
        <h2 class="mb-0 fs-3">📅 Caja Diaria</h2>
        
        <div class="d-flex align-items-center bg-white p-1 rounded border shadow-sm w-100 w-md-auto">
            <span class="input-group-text border-0 bg-transparent"><i class="bi bi-calendar-event"></i></span>
            <input type="date" class="form-control border-0 shadow-none" 
                   @bind="fechaSeleccionada" 
                   @bind:after="CargarHistorial" /> 
        </div>
    </div>

    <div class="row g-2 mb-3">
        <div class="col-12 col-md-4">
            <div class="card bg-primary text-white shadow-sm border-0 h-100">
                <div class="card-body text-center py-3">
                    <small class="opacity-75 text-uppercase ls-1">Total Recaudado</small>
                    <h2 class="fw-bold mb-0">@sesiones?.Sum(s => s.TotalCobrado).ToString("C")</h2>
                </div>
            </div>
        </div>
        
        <div class="col-6 col-md-4">
            <div class="card bg-white shadow-sm border-0 h-100">
                <div class="card-body text-center p-2 py-3">
                    <h6 class="text-muted small mb-1">Sesiones</h6>
                    <h4 class="mb-0 text-dark">@sesiones?.Count</h4>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-4">
            <div class="card bg-white shadow-sm border-0 h-100">
                <div class="card-body text-center p-2 py-3">
                    <h6 class="text-muted small mb-1">Ticket Prom.</h6>
                    <h4 class="mb-0 text-dark">
                        @((sesiones?.Any() == true ? sesiones.Average(s => s.TotalCobrado) : 0).ToString("F2"))
                    </h4>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0 d-none d-md-block">
        <div class="card-body p-0">
            <table class="table table-striped table-hover mb-0 align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>Hora Fin</th>
                        <th>Equipo</th>
                        <th>Duración</th>
                        <th class="text-end">Tiempo (S/)</th>
                        <th class="text-end">Extras (S/)</th>
                        <th class="text-end">Total</th>
                    </tr>
                </thead>
                <tbody>
                    @if (sesiones != null && sesiones.Any())
                    {
                        @foreach (var item in sesiones)
                        {
                            <tr>
                                <td>@item.FechaFin.ToString("hh:mm tt")</td>
                                <td class="fw-bold">@item.PcNombre</td>
                                <td>@((int)item.DuracionMinutos) min</td>
                                <td class="text-end">@item.ImporteTiempo.ToString("N2")</td>
                                <td class="text-end">@item.ImporteExtra.ToString("N2")</td>
                                <td class="text-end fw-bold text-success">@item.TotalCobrado.ToString("C")</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr class="text-center"><td colspan="6" class="py-4 text-muted">Sin movimientos</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="d-md-none">
        @if (sesiones != null && sesiones.Any())
        {
            @foreach (var item in sesiones)
            {
                <div class="card mb-2 shadow-sm border-0">
                    <div class="card-body p-3">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <span class="fw-bold text-primary">@item.PcNombre</span>
                            <span class="badge bg-light text-dark border">@item.FechaFin.ToString("hh:mm tt")</span>
                        </div>
                        
                        <div class="d-flex justify-content-between align-items-end">
                            <div class="small text-muted lh-sm">
                                <div><i class="bi bi-clock"></i> @((int)item.DuracionMinutos) min</div>
                                <div>Tiempo: S/ @item.ImporteTiempo.ToString("N2")</div>
                                @if(item.ImporteExtra > 0){
                                    <div class="text-primary">Extras: S/ @item.ImporteExtra.ToString("N2")</div>
                                }
                            </div>
                            <div class="text-end">
                                <span class="fs-4 fw-bold text-success">@item.TotalCobrado.ToString("C")</span>
                            </div>
                        </div>
                    </div>
                </div>
            }
            
            <div class="card bg-secondary text-white mt-3 mb-5">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <span>TOTAL DEL DÍA:</span>
                    <span class="fs-4 fw-bold">@sesiones.Sum(s => s.TotalCobrado).ToString("C")</span>
                </div>
            </div>
        }
        else
        {
            <div class="text-center py-5 text-muted">
                <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                <p>No hay movimientos hoy.</p>
            </div>
        }
    </div>
</div>

@code {
    private DateTime fechaSeleccionada = DateTime.Today;
    private List<HistorialSesion>? sesiones;

    protected override async Task OnInitializedAsync()
    {
        await CargarHistorial();
        // 3. SUSCRIBIRSE AL EVENTO DEL BOTÓN AMARILLO
        RefreshService.OnRefreshRequested += RecargarDatos;
    }

    private async Task CargarHistorial()
    {
        sesiones = await HistorialService.ObtenerPorFechaAsync(fechaSeleccionada);
    }

    // 4. MÉTODO QUE EJECUTA EL BOTÓN
    private async Task RecargarDatos()
    {
        // Volvemos a pedir los datos de la fecha que esté seleccionada en ese momento
        await CargarHistorial();
        await InvokeAsync(StateHasChanged);
    }

    // 5. LIMPIEZA
    public async ValueTask DisposeAsync()
    {
        RefreshService.OnRefreshRequested -= RecargarDatos;
    }
}