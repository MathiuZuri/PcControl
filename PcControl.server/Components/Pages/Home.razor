@page "/"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.SignalR.Client 
@using PcControl.Shared.Models
@using PcControl.Server.Services
@using PcControl.server.Components.Computers
@attribute [Authorize]
@inject ComputadoraService ComputerService
@inject TarifaService TarifaService
@inject ProductoService ProductoService
@inject NavigationManager NavManager 
@rendermode InteractiveServer
@inject UiRefreshService RefreshService
@implements IAsyncDisposable
@inject PcStatusService StatusService
@inject IJSRuntime JS

<PageTitle>Panel Principal</PageTitle>

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>🖥️ Control de Ciber</h2>
        <button class="btn btn-primary" @onclick="ForzarActualizacionGlobal">
            <i class="bi bi-arrow-clockwise"></i> Sincronizar Todos
        </button>
    </div>

    <div class="row">
        @if (computadoras != null)
        {
            @foreach (var pc in computadoras)
            {
                <PcCard Pc="pc" 
                        OnAlquilar="AbrirModalIniciar" 
                        OnCobrar="AbrirModalCobrar" 
                        OnMensaje="AbrirModalMensaje"
                        />
            }
        }
    </div>
</div>

@* --- MODAL 1: INICIAR / CONFIGURAR / CONTROL REMOTO --- *@
@if (mostrarModalIniciar)
{
    <div class="modal-backdrop-custom">
        <div class="modal-content-custom @(pcSeleccionada.EstaOnline ? "" : "border-danger border-3")">
            
            <div class="d-flex justify-content-between mb-3 align-items-center">
                <h4 class="mb-0">
                    @pcSeleccionada.Nombre 
                    @if (pcSeleccionada.EstaOnline)
                    {
                        <span class="badge bg-success fs-6 ms-2">ONLINE</span>
                    }
                    else
                    {
                        <span class="badge bg-danger fs-6 ms-2">OFFLINE</span>
                    }
                </h4>
                <button class="btn-close" @onclick="CerrarModales"></button>
            </div>

            <ul class="nav nav-tabs mb-3">
                <li class="nav-item">
                    <button class="nav-link @(tabActiva == "tiempo" ? "active" : "")" @onclick='() => tabActiva = "tiempo"'>
                        Tiempo y Venta
                    </button>
                </li>
                <li class="nav-item">
                    <button class="nav-link @(tabActiva == "remoto" ? "active" : "")" @onclick='() => tabActiva = "remoto"'>
                        <i class="bi bi-joystick"></i> Control Remoto
                    </button>
                </li>
            </ul>

            @if (tabActiva == "tiempo")
            {
                <div class="mb-3">
                    <label class="form-label">Tiempo (Minutos) - 0 = Libre</label>
                    <div class="input-group">
                        <input type="number" class="form-control" @bind="pcSeleccionada.TiempoLimiteMinutos" />
                        @if(pcSeleccionada.Estado == "Ocupada" && pcSeleccionada.TiempoLimiteMinutos > 0)
                        {
                            <span class="input-group-text bg-warning">Restan: @pcSeleccionada.MinutosRestantes min</span>
                        }
                    </div>
                </div>

                <div class="card mb-3 border-secondary">
                    <div class="card-header bg-transparent border-secondary py-1">
                        <small class="fw-bold text-secondary">CONSUMOS / TIENDA</small>
                    </div>
                    <div class="card-body p-2">
                        <div class="input-group mb-2">
                            <input type="text" class="form-control form-control-sm" 
                                   placeholder="Buscar producto..." 
                                   @bind="BusquedaProducto"
                                   @bind:event="oninput" />
                            @if (!string.IsNullOrEmpty(busquedaProducto))
                            {
                                <button class="btn btn-sm btn-outline-secondary" @onclick="() => busquedaProducto = string.Empty">
                                    <i class="bi bi-x"></i>
                                </button>
                            }
                        </div>

                        @if (!string.IsNullOrEmpty(busquedaProducto) && productosFiltrados.Any())
                        {
                            <div class="list-group mb-2 shadow-sm" style="max-height: 150px; overflow-y: auto;">
                                @foreach (var prod in productosFiltrados)
                                {
                                    <button type="button" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center py-1 px-2"
                                            @onclick="() => AgregarProducto(prod)">
                                        <span>@prod.Nombre</span>
                                        <span class="badge bg-primary rounded-pill">@prod.Precio.ToString("C")</span>
                                    </button>
                                }
                            </div>
                        }

                        @if (pcSeleccionada.Consumos.Any())
                        {
                            <div class="table-responsive" style="max-height: 150px;">
                                <table class="table table-sm table-borderless mb-0 small">
                                    <tbody>
                                        @foreach (var item in pcSeleccionada.Consumos)
                                        {
                                            <tr>
                                                <td>@item.Cantidad x @item.Nombre</td>
                                                <td class="text-end">@item.Total.ToString("C")</td>
                                                <td class="text-end" style="width: 30px;">
                                                    <i class="bi bi-trash text-danger cursor-pointer" @onclick="() => EliminarConsumo(item)"></i>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                    </div>
                    <div class="card-footer bg-light py-1 d-flex justify-content-between align-items-center">
                        <span class="small fw-bold">Total Extras:</span>
                        <div class="input-group input-group-sm w-50">
                            <span class="input-group-text border-0 bg-transparent">S/</span>
                            <input type="number" step="0.10" class="form-control form-control-sm text-end fw-bold bg-transparent border-0" 
                                   @bind="pcSeleccionada.ImporteExtra" />
                        </div>
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label">Nota Interna</label>
                    <textarea class="form-control" rows="2" @bind="pcSeleccionada.NotaAdmin" placeholder="Ej: DNI en caja..."></textarea>
                </div>
                
                <div class="d-flex gap-2 justify-content-end mt-4">
                    <button class="btn btn-secondary" @onclick="CerrarModales">Cancelar</button>
                    <button class="btn btn-success" @onclick="GuardarInicio">
                        @(pcSeleccionada.Estado == "Disponible" ? "Iniciar Tiempo" : "Guardar Cambios")
                    </button>
                </div>
            }
            
            else if (tabActiva == "remoto")
            {
                <div class="text-center p-2">
                    
                    @if (!pcSeleccionada.EstaOnline)
                    {
                        <div class="alert alert-danger">
                            <i class="bi bi-wifi-off"></i> El equipo está desconectado o apagado.
                            <br/>
                            @if (!string.IsNullOrEmpty(pcSeleccionada.MacAddress))
                            {
                                <button class="btn btn-outline-danger mt-2" @onclick="EncenderPc">
                                    <i class="bi bi-power"></i> Encender (Wake on LAN)
                                </button>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="d-grid gap-2 col-10 mx-auto mb-3">
                            <div class="btn-group">
                                <button class="btn btn-warning" @onclick='() => EnviarComando("Reiniciar")'>
                                    <i class="bi bi-arrow-clockwise"></i> Reiniciar
                                </button>
                                <button class="btn btn-danger" @onclick='() => EnviarComando("Apagar")'>
                                    <i class="bi bi-power"></i> Apagar
                                </button>
                            </div>
                            
                            <div class="btn-group">
                                <button class="btn btn-info text-white @(pcSeleccionada.InicioPausa != null ? "disabled" : "")" 
                                        @onclick='() => TogglePausa(true)'>
                                    <i class="bi bi-pause-circle-fill"></i> Pausar y Bloquear
                                </button>
    
                                <button class="btn btn-outline-info @(pcSeleccionada.InicioPausa == null ? "disabled" : "")" 
                                        @onclick='() => TogglePausa(false)'>
                                    <i class="bi bi-play-circle-fill"></i> Reanudar
                                </button>
                            </div>

                             <button class="btn btn-dark" @onclick='() => EnviarComando("EjecutarCliente")'>
                                <i class="bi bi-window-stack"></i> Traer App al Frente
                            </button>
                        </div>

                        <hr />

                        <h6 class="fw-bold text-primary mb-2"><i class="bi bi-display"></i> Monitor Remoto</h6>

                        <div class="d-flex justify-content-center gap-2 mb-3">
                            <button class="btn btn-sm btn-success" @onclick='() => EnviarComando("StreamStart")'>
                                <i class="bi bi-broadcast"></i> Activar Transmisión
                            </button>
    
                            <a href="monitor/@pcSeleccionada.Nombre" target="_blank" class="btn btn-sm btn-primary">
                                <i class="bi bi-box-arrow-up-right"></i> Abrir Visor
                            </a>
    
                            <button class="btn btn-sm btn-danger" @onclick='() => EnviarComando("StreamStop")'>
                                <i class="bi bi-stop-circle"></i> Detener
                            </button>
                        </div>

                        <div class="alert alert-info py-1">
                            <small><i class="bi bi-info-circle"></i> Primero activa la transmisión, luego abre el visor.</small>
                        </div>

                        @if (!string.IsNullOrEmpty(pcSeleccionada.UltimaCapturaBase64))
                        {
                            <div class="mt-2 p-1 border border-2 border-primary rounded bg-dark" style="min-height: 200px;">
                                <img src="data:image/jpeg;base64,@pcSeleccionada.UltimaCapturaBase64" 
                                     class="img-fluid border border-3 border-success mt-2"
                                     style="max-height: 300px; width: auto;" 
                                     alt="Esperando transmisión..." />
                                     
                                <div class="text-white small mt-1">
                                    <span class="spinner-grow spinner-grow-sm text-danger" role="status"></span> Transmitiendo en Vivo
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="alert alert-secondary mt-2">
                                <small>Dale a "Iniciar Video" para ver la pantalla.</small>
                            </div>
                        }
                    }
                    
                    <div class="mt-3 text-muted small border-top pt-2">
                        IP: @(pcSeleccionada.IpAddress ?? "...") | MAC: @(pcSeleccionada.MacAddress ?? "...")
                    </div>
                </div>
            }
        </div>
    </div>
}

@* --- MODAL 2: COBRAR (CON CÁLCULO AUTOMÁTICO) --- *@
@if (mostrarModalCobrar)
{
    <div class="modal-backdrop-custom">
        <div class="modal-content-custom">
            <div class="d-flex justify-content-between mb-3">
                <h4>Cobrar: @pcSeleccionada.Nombre</h4>
                <button class="btn-close" @onclick="CerrarModales"></button>
            </div>

            <div class="alert alert-info py-2">
                <div class="row">
                    <div class="col-6">
                        <small>Inicio:</small><br/>
                        <strong>@pcSeleccionada.HoraInicio?.ToString("hh:mm tt")</strong>
                    </div>
                    <div class="col-6 text-end">
                        <small>Tiempo Transcurrido:</small><br/>
                        <strong>@((pcSeleccionada?.HoraInicio != null) ? (int)(DateTime.Now - pcSeleccionada.HoraInicio.Value).TotalMinutes : 0) min</strong>
                    </div>
                </div>
            </div>
            
            @* --- NUEVO: AQUÍ MOSTRAMOS LA NOTA SI EXISTE --- *@
            @if (!string.IsNullOrWhiteSpace(pcSeleccionada.NotaAdmin))
            {
                <div class="alert alert-warning d-flex align-items-center" role="alert">
                    <i class="bi bi-exclamation-triangle-fill flex-shrink-0 me-2"></i>
                    <div>
                        <strong>Nota:</strong> @pcSeleccionada.NotaAdmin
                    </div>
                </div>
            }

            <table class="table table-borderless align-middle">
                <tbody>
                    <tr>
                        <td class="w-50">Consumo de Tiempo:</td>
                        <td>
                            <div class="input-group">
                                <span class="input-group-text bg-white border-end-0">S/</span>
                                <input type="number" 
                                       step="0.10" 
                                       class="form-control text-end fw-bold border-start-0" 
                                       @bind="pcSeleccionada.ImportePorTiempo" 
                                       @bind:event="oninput" /> 
                                       </div>
                            @if (precioSugerido != pcSeleccionada.ImportePorTiempo)
                            {
                                <small class="text-muted d-block text-end fst-italic">
                                    Sugerido por sistema: @precioSugerido.ToString("C")
                                </small>
                            }
                        </td>
                    </tr>
                    <tr>
                        <td>Extras / Consumo:</td>
                        <td>
                            <div class="input-group">
                                <span class="input-group-text bg-white border-end-0">S/</span>
                                <input type="number" step="0.10" class="form-control text-end border-start-0" 
                                       @bind="pcSeleccionada.ImporteExtra" 
                                       @bind:event="oninput" />
                            </div>
                        </td>
                    </tr>
                    <tr class="border-top">
                        <td class="pt-3"><strong>Subtotal:</strong></td>
                        <td class="text-end pt-3 h5">
                            @((pcSeleccionada.ImportePorTiempo + pcSeleccionada.ImporteExtra).ToString("C"))
                        </td>
                    </tr>
                </tbody>
            </table>

            <div class="mb-3 row align-items-center bg-light p-2 rounded mx-0">
                <label class="col-5 col-form-label fw-bold">Descuento:</label>
                <div class="col-7">
                    <input type="number" class="form-control text-end" @bind="descuento" @bind:event="oninput" placeholder="0.00" />
                </div>
            </div>
            
            <div class="text-center mb-4">
                <small class="text-uppercase text-muted ls-1">Total a Cobrar</small>
                <div class="display-6 fw-bold text-primary">
                    @((pcSeleccionada.ImportePorTiempo + pcSeleccionada.ImporteExtra - descuento).ToString("C"))
                </div>
            </div>

            <div class="mb-3 row">
                <label class="col-4 col-form-label">Paga con:</label>
                <div class="col-8">
                    <input type="number" class="form-control" @bind="pagoCon" @bind:event="oninput" placeholder="S/" />
                </div>
            </div>

            @if(pagoCon > 0)
            {
                <div class="alert @(CalcularVuelto() >= 0 ? "alert-success" : "alert-danger") text-center py-2">
                    <strong>Vuelto: @CalcularVuelto().ToString("C")</strong>
                </div>
            }

            <div class="d-flex justify-content-between align-items-center mt-4 pt-3 border-top">
                <button class="btn btn-outline-danger" @onclick="AnularSesionConfirmada">
                    <i class="bi bi-trash"></i> Anular Tiempo
                </button>
                
                <div class="d-flex gap-2">
                    <button class="btn btn-secondary" @onclick="CerrarModales">Cancelar</button>
                    <button class="btn btn-danger px-4 shadow-sm" @onclick="ConfirmarCobro">
                        <i class="bi bi-cash-coin"></i> Finalizar Cobro
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@* --- MODAL 3: ENVIAR MENSAJE --- *@
@if (mostrarModalMensaje)
{
    <div class="modal-backdrop-custom">
        <div class="modal-content-custom" style="max-width: 400px;"> 
            <div class="d-flex justify-content-between mb-3">
                <h5>Mensaje para @pcSeleccionada.Nombre <i class="bi bi-chat-dots text-primary"></i></h5>
                <button class="btn-close" @onclick="CerrarModales"></button>
            </div>

            <div class="mb-3">
                <label class="form-label text-muted small">Escribe el mensaje que aparecerá en la pantalla del cliente</label>
                <textarea class="form-control" rows="3" @bind="mensajeParaPc" placeholder="Ej: Su tiempo está por terminar..." autofocus></textarea>
            </div>

            <div class="d-flex gap-2 justify-content-end">
                <button class="btn btn-secondary btn-sm" @onclick="CerrarModales">Cancelar</button>
                <button class="btn btn-primary btn-sm" @onclick="EnviarMensajeConfirmado">
                    <i class="bi bi-send-fill"></i> Enviar
                </button>
            </div>
        </div>
    </div>
}

@* --- CONTENEDOR DE ALERTAS FLOTANTES (TOASTS) --- *@
<div class="toast-container position-fixed bottom-0 end-0 p-3" style="z-index: 9999;">
    @foreach (var alerta in alertasActivas)
    {
        <div class="toast show align-items-center text-bg-warning border-0 mb-3 shadow-lg" role="alert">
            <div class="d-flex">
                <div class="toast-body fw-bold fs-6">
                    <i class="bi bi-bell-fill text-danger animate-pulse me-2"></i> 
                    ¡Tiempo finalizado en @alerta.PcNombre!
                </div>
                <button type="button" class="btn-close me-2 m-auto" @onclick="() => alertasActivas.Remove(alerta)"></button>
            </div>
        </div>
    }
</div>

@* --- SINTETIZADOR DE SONIDO (NO REQUIERE ARCHIVOS MP3) --- *@
<script>
    window.reproducirAlertaCiber = function() {
        try {
            var context = new (window.AudioContext || window.webkitAudioContext)();
            var oscillator = context.createOscillator();
            var gainNode = context.createGain();
            
            oscillator.connect(gainNode);
            gainNode.connect(context.destination);
            
            // Tono agudo de alerta (Nota La)
            oscillator.type = 'sine';
            oscillator.frequency.value = 880; 
            
            // Volumen con desvanecimiento suave
            gainNode.gain.setValueAtTime(0.5, context.currentTime);
            gainNode.gain.exponentialRampToValueAtTime(0.001, context.currentTime + 0.5);
            
            oscillator.start(context.currentTime);
            oscillator.stop(context.currentTime + 0.5);
        } catch(e) { console.log("Audio no soportado"); }
    };
</script>

@code {
    private List<Computadora>? computadoras;
    private Computadora pcSeleccionada = new();
    
    // Control de Modales
    private bool mostrarModalIniciar = false;
    private bool mostrarModalCobrar = false;
    private bool mostrarModalMensaje = false;

    private decimal descuento = 0;
    private decimal pagoCon = 0;
    private string mensajeParaPc = "";
    private System.Threading.Timer? timer;
    
    private decimal precioSugerido = 0;
    
    // VARIABLES PARA PRODUCTOS
    private List<Producto> todosLosProductos = new();
    private List<Producto> productosFiltrados = new();
    private string busquedaProducto = "";
    
    private HubConnection? hubConnection;
    private string tabActiva = "tiempo"; // Controla qué pestaña del modal se ve
    
    private async Task AbrirModalCobrar(Computadora pc)
    {
        pcSeleccionada = pc;
        descuento = 0;
        pagoCon = 0;
        
        if (pc.HoraInicio.HasValue)
        {
            // 1. CALCULAMOS EL PRECIO "SUGERIDO" (Solo como referencia)
            var tiempoTranscurrido = DateTime.Now - pc.HoraInicio.Value;
            int minutosTotales = (int)Math.Ceiling(tiempoTranscurrido.TotalMinutes);
            
            // Guardamos el cálculo del sistema
            precioSugerido = await TarifaService.CalcularPrecioTotal(minutosTotales);

            // 2. ASIGNAMOS EL PRECIO INICIAL
            // Esto rellena el input, pero el usuario puede borrarlo y poner lo que quiera.
            pcSeleccionada.ImportePorTiempo = precioSugerido;
        }
        else
        {
            pcSeleccionada.ImportePorTiempo = 0;
            precioSugerido = 0;
        }

        mostrarModalCobrar = true;
    }
    
    // FILTRO DE BÚSQUEDA
    // Esta propiedad se enlaza al input. Al cambiar, filtra la lista.
    private string BusquedaProducto
    {
        get => busquedaProducto;
        set
        {
            busquedaProducto = value;
            if (string.IsNullOrWhiteSpace(value))
            {
                productosFiltrados.Clear();
            }
            else
            {
                productosFiltrados = todosLosProductos
                    .Where(p => p.Nombre.Contains(value, StringComparison.OrdinalIgnoreCase) && p.Stock > 0)
                    .Take(5) // Solo mostrar los top 5 para no llenar la pantalla
                    .ToList();
            }
        }
    }
    
    // MÉTODO: Agregar Producto a la PC
    private void AgregarProducto(Producto prod)
    {
        // 1. Buscar si ya existe en la lista de consumos de esta PC
        var existente = pcSeleccionada.Consumos.FirstOrDefault(c => c.Nombre == prod.Nombre);

        if (existente != null)
        {
            existente.Cantidad++;
        }
        else
        {
            pcSeleccionada.Consumos.Add(new ProductoConsumo
            {
                Nombre = prod.Nombre,
                Precio = prod.Precio,
                Cantidad = 1
            });
        }

        // 2. ACTUALIZAR EL IMPORTE EXTRA AUTOMÁTICAMENTE
        RecalcularImporteExtra();

        // 3. Limpiar buscador
        busquedaProducto = "";
        productosFiltrados.Clear();
    }
    // METODO: Quitar Producto
    private void EliminarConsumo(ProductoConsumo item)
    {
        pcSeleccionada.Consumos.Remove(item);
        RecalcularImporteExtra();
    }

    private void RecalcularImporteExtra()
    {
        // Sumamos la lista de consumos
        pcSeleccionada.ImporteExtra = pcSeleccionada.Consumos.Sum(c => c.Total);
    }
    
protected override async Task OnInitializedAsync()
    {
        await CargarDatos();
        todosLosProductos = await ProductoService.ObtenerTodosAsync();
        
        // 1. CONEXIÓN SIGNALR
        hubConnection = new HubConnectionBuilder()
            .WithUrl(NavManager.ToAbsoluteUri("/ciberhub"))
            .Build();
        
        hubConnection.On("RefrescarDashboard", async () =>
        {
            await CargarDatos();
            await InvokeAsync(StateHasChanged);
        });

        hubConnection.On<string, bool>("ActualizarLatidoFull", (nombrePc, pausada) =>
        {
            var pc = computadoras?.FirstOrDefault(c => c.Nombre == nombrePc);
            if (pc != null)
            {
                pc.UltimoLatido = DateTime.Now; 
                pc.EstaPausada = pausada;       
                InvokeAsync(StateHasChanged);
            }
        });
        
        hubConnection.On<string>("StreamDetenido", (nombrePc) =>
        {
            if (pcSeleccionada.Nombre == nombrePc)
            {
                pcSeleccionada.UltimaCapturaBase64 = null; 
                InvokeAsync(StateHasChanged);
            }
        });

        hubConnection.On<string, string>("RecibirCaptura", (nombrePc, base64) =>
        {
            if (pcSeleccionada.Nombre == nombrePc)
            {
                pcSeleccionada.UltimaCapturaBase64 = base64;
                InvokeAsync(StateHasChanged);
            }
        });

        // --- NUEVO: RECEPTOR DE LA ALERTA DE TIEMPO AGOTADO ---
        hubConnection.On<string>("PC_TiempoAgotado_Alerta", async (nombrePc) =>
        {
            // Verificamos que no exista ya una alerta en pantalla para esta misma PC
            // Esto evita que el sonido se repita en bucle si el servidor manda la alerta 2 veces
            if (!alertasActivas.Any(a => a.PcNombre == nombrePc))
            {
                // 1. Añadimos la PC a la lista para que el HTML dibuje el "Toast" flotante
                alertasActivas.Add(new AlertaTiempo { PcNombre = nombrePc });
                
                // 2. Disparamos la función JavaScript que reproduce el tono
                try 
                {
                    await JS.InvokeVoidAsync("reproducirAlertaCiber");
                }
                catch { /* Ignorar silenciosamente si el navegador bloquea el audio automático */ }
                
                // 3. Forzamos la actualización visual para que aparezca la notificación al instante
                await InvokeAsync(StateHasChanged);
            }
        });
        // ------------------------------------------------------

        await hubConnection.StartAsync();

        // 2. REFRESCAR UI CADA 1 SEGUNDO (Esto elimina la sensación de latencia)
        timer = new System.Threading.Timer(async _ => { await InvokeAsync(StateHasChanged); }, null, 0, 1000);

        RefreshService.OnRefreshRequested += ForzarActualizacionGlobal; 
    }
    
    private async Task TogglePausa(bool pausar)
    {
        // 1. Llamamos al servicio que hace la magia (Pausa tiempo + Bloquea Input)
        await ComputerService.AlternarPausaAsync(pcSeleccionada.Id, pausar);
        
        // 2. Recargamos los datos para ver el cambio de estado/color
        await CargarDatos(); 
        
        // 3. Actualizamos la variable local del modal para que los botones reaccionen
        var pcActualizada = computadoras?.FirstOrDefault(c => c.Id == pcSeleccionada.Id);
        if (pcActualizada != null)
        {
            pcSeleccionada = pcActualizada;
        }
    }
    
    private async Task EnviarComando(string comando)
    {
        await ComputerService.EnviarComandoAsync(pcSeleccionada.Nombre, comando);
    }

    private async Task EncenderPc()
    {
        await ComputerService.EncenderPcAsync(pcSeleccionada.Id);
    }

    private async Task SolicitarCaptura()
    {
        pcSeleccionada.UltimaCapturaBase64 = null; // Limpiar anterior
        await EnviarComando("Captura");
    }

    private async Task CargarDatos()
    {
    // 1. Traemos la data fresca de la base de datos (Nombres, Precios, Estado DB)
    var nuevasPcs = await ComputerService.ObtenerTodasAsync();

    // 2. RECUPERACIÓN DE ESTADO (La solución a la latencia)
    foreach (var pcNueva in nuevasPcs)
        {
            // A. PRIORIDAD 1: Consultar al "Cerebro Global" (StatusService)
            // Esto arregla que aparezca desconectada al cambiar de pestaña o recargar.
            var estadoMemoria = StatusService.ObtenerEstado(pcNueva.Nombre);
            if (estadoMemoria != null && estadoMemoria.EstaOnline)
            {
                pcNueva.UltimoLatido = estadoMemoria.UltimoLatido;
                pcNueva.EstaPausada = estadoMemoria.EstaPausada;
            }

            // B. PRIORIDAD 2: Preservar datos visuales locales (Como la captura de video)
            // Esto evita que la imagen parpadee si solo diste clic al botón "Sincronizar".
            if (computadoras != null)
            {
                var pcVieja = computadoras.FirstOrDefault(c => c.Id == pcNueva.Id);
                if (pcVieja != null)
                {
                    // Solo copiamos la captura, el estado online ya lo tomamos del servicio global
                    if (!string.IsNullOrEmpty(pcVieja.UltimaCapturaBase64))
                    {
                        pcNueva.UltimaCapturaBase64 = pcVieja.UltimaCapturaBase64;
                    }
                    
                    // Si por alguna razón el servicio global falló pero localmente la teníamos online,
                    // mantenemos el dato local para mayor seguridad.
                    if (pcVieja.UltimoLatido > pcNueva.UltimoLatido)
                    {
                        pcNueva.UltimoLatido = pcVieja.UltimoLatido;
                    }
                }
            }
        }

        // 3. Ahora sí, actualizamos la lista de la vista
        computadoras = nuevasPcs;
        
        // Actualizamos también la pcSeleccionada si está abierto el modal
        if (mostrarModalIniciar || mostrarModalCobrar)
        {
            var pcRefrescada = computadoras.FirstOrDefault(c => c.Id == pcSeleccionada.Id);
            if (pcRefrescada != null)
            {
                // Truco: Mantenemos la referencia visual para que el modal no se cierre o parpadee
                // pero actualizamos sus valores internos
                pcSeleccionada.Estado = pcRefrescada.Estado;
                pcSeleccionada.HoraInicio = pcRefrescada.HoraInicio;
                pcSeleccionada.ImporteExtra = pcRefrescada.ImporteExtra;
                pcSeleccionada.UltimoLatido = pcRefrescada.UltimoLatido;
                // No sobreescribimos 'Consumos' aquí para no borrar lo que estés editando en el modal
            }
        }
    }

    // --- MODAL CONFIGURAR ---
    private void AbrirModalIniciar(Computadora pc)
    {
        pcSeleccionada = pc;
        if (pcSeleccionada.ImporteExtra > 0 && (pcSeleccionada.Consumos == null || !pcSeleccionada.Consumos.Any()))
        {
            if (pcSeleccionada.Consumos == null) pcSeleccionada.Consumos = new List<ProductoConsumo>();
            
            pcSeleccionada.Consumos.Add(new ProductoConsumo
            {
                Nombre = "(Acumulado Anterior)",
                Precio = pcSeleccionada.ImporteExtra,
                Cantidad = 1
            });
        }
        mostrarModalIniciar = true;
    }

    // --- MODAL MENSAJE ---
    private void AbrirModalMensaje(Computadora pc)
    {
        pcSeleccionada = pc;
        mensajeParaPc = ""; 
        mostrarModalMensaje = true;
    }

    private async Task EnviarMensajeConfirmado()
    {
        if (!string.IsNullOrWhiteSpace(mensajeParaPc))
        {
            await ComputerService.EnviarMensajeAsync(pcSeleccionada.Nombre, mensajeParaPc);
            mostrarModalMensaje = false;
        }
    }

    // --- GUARDAR / COBRAR ---
    private async Task GuardarInicio()
    {
        if (pcSeleccionada.Estado == "Disponible")
        {
            pcSeleccionada.Estado = "Ocupada";
            pcSeleccionada.HoraInicio = DateTime.Now;
            // Al iniciar, el importe por tiempo arranca en 0 (o tarifa mínima si quisieras)
            pcSeleccionada.ImportePorTiempo = 0; 
        }
        await ComputerService.ActualizarPcAsync(pcSeleccionada);
        await CargarDatos();
        mostrarModalIniciar = false;
    }

    private async Task ConfirmarCobro()
    {
        decimal totalFinal = (pcSeleccionada.ImportePorTiempo + pcSeleccionada.ImporteExtra) - descuento;

        // 1. Enviamos la PC (que lleva la lista .Consumos dentro) al servicio
        await ComputerService.CobrarYFinalizarAsync(pcSeleccionada, totalFinal, "Efectivo");

        // 2. Limpiamos la lista visual localmente
        pcSeleccionada.Consumos.Clear();

        // 3. Recargamos datos
        await CargarDatos(); 
        
        // Recargamos productos para ver el stock actualizado en el buscador
        todosLosProductos = await ProductoService.ObtenerTodosAsync(); 
        
        mostrarModalCobrar = false;
    }
    
    private async Task ForzarActualizacionGlobal()
    {
        await ComputerService.NotificarCambioManual();
        // Recargar datos locales también
        await CargarDatos();
        await InvokeAsync(StateHasChanged);
    }
    
    private void CerrarModales()
    {
        mostrarModalIniciar = false;
        mostrarModalCobrar = false;
        mostrarModalMensaje = false;
        tabActiva = "tiempo"; // Resetear tab al cerrar
    }
    
    private decimal CalcularVuelto()
    {
        decimal totalFinal = (pcSeleccionada.ImportePorTiempo + pcSeleccionada.ImporteExtra) - descuento;
        return pagoCon - totalFinal;
    }
    public async ValueTask DisposeAsync()
    {
        RefreshService.OnRefreshRequested -= ForzarActualizacionGlobal; // Descomentar si usas el servicio
        if (hubConnection is not null)
        {
            await hubConnection.DisposeAsync();
        }
        if (timer != null)
        {
            await timer.DisposeAsync();
        }
    }
    
    private List<AlertaTiempo> alertasActivas = new();

    public class AlertaTiempo
    {
        public string PcNombre { get; set; } = "";
        public DateTime HoraAlerta { get; set; } = DateTime.Now;
    }
    
    private async Task AnularSesionConfirmada()
    {
        // Usamos un confirm de JavaScript simple para evitar anulaciones accidentales
        bool confirmado = await JS.InvokeAsync<bool>("confirm", 
            $"¿Estás seguro de ANULAR la sesión de {pcSeleccionada.Nombre}? \n\nEsto NO registrará ingresos en caja y liberará la PC.");

        if (confirmado)
        {
            await ComputerService.AnularSesionAsync(pcSeleccionada.Id);
            mostrarModalCobrar = false;
            await CargarDatos(); // Recargar la lista visual
        }
    }
}