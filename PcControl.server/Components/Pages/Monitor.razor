@page "/monitor/{NombrePc}"
@using Microsoft.AspNetCore.SignalR.Client
@using PcControl.Shared.Models
@using PcControl.Server.Services
@inject NavigationManager NavManager
@inject ComputadoraService ComputerService
@rendermode InteractiveServer

<PageTitle>Monitor: @NombrePc</PageTitle>

<div class="container-fluid vh-100 d-flex flex-column align-items-center justify-content-center bg-dark">
    
    @if (conectado)
    {
        <div class="position-relative border border-3 border-success shadow-lg" style="max-width: 95%; max-height: 90vh;">
            @if (!string.IsNullOrEmpty(imagenBase64))
            {
                <img src="data:image/jpeg;base64,@imagenBase64" class="img-fluid" style="object-fit: contain; max-height: 85vh;" />
            }
            else
            {
                <div class="text-white p-5 text-center">
                    <div class="spinner-border text-primary" role="status"></div>
                    <p class="mt-3">Esperando transmisión de @NombrePc...</p>
                    <small class="text-muted">Asegúrate de haber dado click a "Iniciar Video" en el panel principal.</small>
                </div>
            }
            
            <div class="position-absolute top-0 start-0 m-2">
                <span class="badge bg-danger animate-pulse">EN VIVO</span>
            </div>
        </div>
    }
    else
    {
        <div class="text-white">Conectando al servidor...</div>
    }

    <div class="mt-3">
        <button class="btn btn-outline-light btn-sm" @onclick="Cerrar">Cerrar Monitor</button>
    </div>
</div>

<style>
    body { background-color: #212529; }
    .animate-pulse { animation: pulse 1s infinite; }
    @@keyframes pulse { 0% { opacity: 1; } 50% { opacity: 0.5; } 100% { opacity: 1; } }
</style>

@code {
    [Parameter] public string NombrePc { get; set; } = "";
    
    private HubConnection? hubConnection;
    private string? imagenBase64;
    private bool conectado = false;

    protected override async Task OnInitializedAsync()
    {
        hubConnection = new HubConnectionBuilder()
            .WithUrl(NavManager.ToAbsoluteUri("/ciberhub"))
            .WithAutomaticReconnect()
            .Build();

        hubConnection.On<string, string>("RecibirCaptura", (pc, base64) =>
        {
            // Solo actualizamos si la imagen es para ESTA pc
            if (pc == NombrePc)
            {
                imagenBase64 = base64;
                InvokeAsync(StateHasChanged);
            }
        });
        
        // 2. NUEVO: Escuchar orden de detener (LIMPIAR PANTALLA)
        hubConnection.On<string>("StreamDetenido", (pc) =>
        {
            if (pc == NombrePc)
            {
                imagenBase64 = null; // <--- ESTO BORRA LA FOTO
                InvokeAsync(StateHasChanged);
            }
        });

        await hubConnection.StartAsync();
        conectado = true;
        
        // Opcional: Forzar inicio de stream al abrir la pestaña
        // await ComputerService.EnviarComandoAsync(NombrePc, "StreamStart");
    }

    private void Cerrar()
    {
        // Opcional: Detener stream al cerrar
        // ComputerService.EnviarComandoAsync(NombrePc, "StreamStop");
        NavManager.NavigateTo("/"); // Volver al home o cerrar pestaña con JS
    }

    public async ValueTask DisposeAsync()
    {
        if (hubConnection is not null)
        {
            await hubConnection.DisposeAsync();
        }
    }
}