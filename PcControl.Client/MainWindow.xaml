<Window x:Class="PcControl.Client.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CyberControl Locked" 
        Height="450" Width="800"
        WindowStyle="None" 
        WindowState="Maximized" 
        Topmost="True" 
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="#1a1a1a"
        KeyDown="Window_KeyDown"> <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="COMPUTADORA BLOQUEADA" Foreground="Red" FontSize="48" FontWeight="Bold" HorizontalAlignment="Center"/>
            <TextBlock x:Name="txtMensaje" Text="Diríjase a caja para activar este equipo" Foreground="White" FontSize="24" Margin="0,20,0,0" HorizontalAlignment="Center"/>
            <TextBlock x:Name="txtEstadoConexion" Text="Conectando..." Foreground="Gray" FontSize="16" Margin="0,50,0,0" HorizontalAlignment="Center"/>
        </StackPanel>

        <Grid x:Name="GridAdminConsole" Visibility="Collapsed" Background="#CC000000">
            <Border Background="#222" BorderBrush="#00FF00" BorderThickness="2" 
                    Width="400" Height="200" CornerRadius="10" VerticalAlignment="Center" HorizontalAlignment="Center">
                <StackPanel Margin="20" VerticalAlignment="Center">
                    <TextBlock Text="CONSOLA DE ADMINISTRADOR" Foreground="#00FF00" FontFamily="Consolas" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                    
                    <TextBlock Text="Ingrese Contraseña:" Foreground="White" FontFamily="Consolas"/>
                    <PasswordBox x:Name="txtPasswordAdmin" 
                                 KeyDown="txtPasswordAdmin_KeyDown"
                                 Margin="0,5,0,20" Padding="5" Background="#333" Foreground="White" BorderBrush="#00FF00"/>
                    
                    <Button Content="DESBLOQUEAR / CERRAR APP" Click="BtnAdminUnlock_Click" 
                            Background="#00FF00" Foreground="Black" FontWeight="Bold" Height="30"/>
                    
                    <Button Content="Cancelar" Click="BtnCancelar_Click" 
                            Background="Transparent" Foreground="Gray" BorderThickness="0" Margin="0,10,0,0"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>