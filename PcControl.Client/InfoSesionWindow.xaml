<Window x:Class="PcControl.Client.InfoSesionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sesión" 
        Height="200" Width="270"
        WindowStyle="None" 
        AllowsTransparency="True" 
        Background="Transparent"
        Topmost="True" 
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Window.Effect>
        <DropShadowEffect Color="Black" BlurRadius="10" ShadowDepth="3" Opacity="0.55"/>
    </Window.Effect>

    <Border x:Name="BordePrincipal" 
            Margin="5"
            CornerRadius="8" 
            Background="#F215151C" 
            BorderBrush="#00D1FF" 
            BorderThickness="1.5"
            ClipToBounds="True"> 
        
        <Grid Margin="15,12,15,12" VerticalAlignment="Top">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> 
                <RowDefinition Height="Auto"/> 
                <RowDefinition Height="Auto"/> 
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,0,2">
                <TextBlock x:Name="txtTiempo" Text="-- min" FontFamily="Segoe UI" FontSize="26" Foreground="#00FF66" FontWeight="Black"/>
                <TextBlock x:Name="txtMensaje" Text="Bienvenido" FontFamily="Segoe UI" FontSize="12" Foreground="#00D1FF" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
            </StackPanel>

            <Button x:Name="BtnToggle" Grid.Row="0" Grid.Column="1" Content="—" Width="28" Height="28" 
                    Background="#26FFFFFF" Foreground="White" BorderThickness="0" FontSize="14" FontWeight="Bold"
                    Click="BtnMinimizar_Click" Cursor="Hand" VerticalAlignment="Top" HorizontalAlignment="Right">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="6"/>
                    </Style>
                </Button.Resources>
            </Button>

            <Rectangle x:Name="Separador" Grid.Row="1" Grid.ColumnSpan="2" Height="1" Fill="#4D00D1FF" Margin="0,10,0,12"/>

            <Grid x:Name="PanelDetalles" Grid.Row="2" Grid.ColumnSpan="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Inicio:" FontFamily="Segoe UI" Foreground="#B3B3B3" FontSize="12" Margin="0,0,10,6"/>
                <TextBlock x:Name="txtHoraInicio" Grid.Row="0" Grid.Column="1" Text="--" FontFamily="Segoe UI" Foreground="#F2F2F2" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Right" Margin="0,0,0,6"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Fin estimado:" FontFamily="Segoe UI" Foreground="#B3B3B3" FontSize="12" Margin="0,0,10,6"/>
                <TextBlock x:Name="txtHoraFin" Grid.Row="1" Grid.Column="1" Text="--" FontFamily="Segoe UI" Foreground="#F2F2F2" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Right" Margin="0,0,0,6"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Tiempo total:" FontFamily="Segoe UI" Foreground="#B3B3B3" FontSize="12" Margin="0,0,10,6"/>
                <TextBlock x:Name="txtTiempoComprado" Grid.Row="2" Grid.Column="1" Text="--" FontFamily="Segoe UI" Foreground="#F2F2F2" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Right" Margin="0,0,0,6"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="Importe:" FontFamily="Segoe UI" Foreground="#00D1FF" FontSize="13" FontWeight="Bold" Margin="0,2,10,0"/>
                <TextBlock x:Name="txtPrecio" Grid.Row="3" Grid.Column="1" Text="S/ 0.00" FontFamily="Segoe UI" Foreground="#FFD700" FontSize="14" FontWeight="Bold" HorizontalAlignment="Right" Margin="0,2,0,0"/>
            </Grid>
        </Grid>
    </Border>
</Window>