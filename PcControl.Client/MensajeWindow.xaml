<Window x:Class="PcControl.Client.MensajeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Mensaje del Admin" Height="150" Width="400"
        WindowStyle="None" 
        AllowsTransparency="True" 
        Background="Transparent"
        Topmost="True" 
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Border CornerRadius="15" Background="#E6000000" BorderBrush="#00D1FF" BorderThickness="2">
        <Grid Margin="15">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="MENSAJE DEL ADMINISTRADOR" Foreground="#00D1FF" FontWeight="Bold" HorizontalAlignment="Center"/>

            <TextBlock Grid.Row="1" x:Name="txtContenido" 
                       Text="..." 
                       Foreground="White" 
                       FontSize="16" 
                       TextWrapping="Wrap" 
                       VerticalAlignment="Center" 
                       HorizontalAlignment="Center" 
                       TextAlignment="Center"/>

            <Button Grid.Row="2" Content="ENTENDIDO (OK)" Click="BtnOk_Click"
                    Background="#00D1FF" Foreground="Black" FontWeight="Bold"
                    Height="30" Width="150" Cursor="Hand">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="5"/>
                    </Style>
                </Button.Resources>
            </Button>
            
            <TextBlock Grid.Row="2" x:Name="txtCuentaAtras" Text="5s" 
                       Foreground="Gray" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0"/>
        </Grid>
    </Border>
</Window>